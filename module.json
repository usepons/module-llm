{
  "id": "llm",
  "name": "LLM Services",
  "version": "1.0.0",
  "description": "Provider registry, model routing, auth profiles, cost tracking, and interactive chat",
  "provides": ["providerRegistry", "authProfileManager", "model-router", "cost-tracker"],
